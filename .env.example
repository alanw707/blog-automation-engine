# =============================================================================
# Autoblogger Environment Variables
# =============================================================================
# Copy to .env and fill in your values. Never commit .env to git.

# -- Claude AI (required for content generation) --
CLAUDE_API_KEY=sk-ant-...

# -- OpenAI (required for embedding-based deduplication) --
OPENAI_API_KEY=sk-...
OPENAI_PROJECT=               # Optional: OpenAI project ID

# -- WordPress (required for wordpress publisher) --
WP_REST_PASSWORD=              # Application password for WP REST API

# -- Azure Blob Storage (required for azure-blob publisher) --
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...

# -- Notifications (optional) --
BREVO_API_KEY=                 # Brevo/Sendinblue transactional email API key

# -- Google Search Console (optional, for GSC auto-refresh) --
# Set in config YAML via gsc.credentials path, or:
GSC_CREDENTIALS_PATH=/path/to/service-account.json
