# ── AI Models ──────────────────────────────────────────────────────────────
# Anthropic (Claude) — available in OpenClaw env as ANTHROPIC_API_KEY
ANTHROPIC_API_KEY=

# OpenAI (embeddings / deduplication) — available in OpenClaw env as OPENAI_API_KEY
OPENAI_API_KEY=

# ── Publishing: Azure Blob Storage ─────────────────────────────────────────
# Required for aiprofilephotomaker.yaml (azure_blob publisher)
# Get from Azure Portal → Storage Account → Access Keys
# Or from the project's .env / Azure Key Vault
AZURE_STORAGE_CONNECTION_STRING=

# ── Publishing: WordPress ──────────────────────────────────────────────────
# Required for svicloudtvbox.yaml (wordpress publisher)
WP_REST_PASSWORD=

# ── Optional: Notifications ────────────────────────────────────────────────
SMTP_PASSWORD=
BREVO_API_KEY=
